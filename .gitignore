# Monorepo root .gitignore (Backend + Frontend)

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/dist-ssr/
**/build/

# Logs
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test / coverage
**/coverage/
**/.nyc_output/

# Environment files
.env
.env.local
.env.*.local
Backend/.env
Frontend/.env

# Runtime / upload artifacts
Backend/uploads/

# Prisma generated artifacts
Backend/.prisma/

# Temporary files
*.tmp
*.temp
tmp/

# OS files
.DS_Store
Thumbs.db

# IDE / editor files
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# Optional local scratch files
test.html
api-1.json
