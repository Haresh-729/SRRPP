generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  engineType      = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model agreement_rent_cycles {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agreement_id String         @db.Uuid
  cycle_number Int
  start_date   DateTime       @db.Date
  end_date     DateTime       @db.Date
  monthly_rent Decimal        @db.Decimal(12, 2)
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  agreements   agreements     @relation(fields: [agreement_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_arc_agreement")
  rent_ledgers rent_ledgers[]

  @@unique([agreement_id, cycle_number])
  @@schema("public")
}

model agreements {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id             String                  @db.Uuid
  tenant_id               String                  @db.Uuid
  broker_id               String?                 @db.Uuid
  agreement_pdf           String?                 @db.VarChar(500)
  duration_months         Int
  start_date              DateTime                @db.Date
  end_date                DateTime                @db.Date
  monthly_rent            Decimal                 @db.Decimal(12, 2)
  rent_escalation_percent Decimal?                @db.Decimal(5, 2)
  rent_due_day            Int
  deposit_amount          Decimal                 @db.Decimal(12, 2)
  status                  AgreementStatus         @default(ACTIVE)
  terminated_at           DateTime?               @db.Timestamp(6)
  termination_reason      String?
  created_at              DateTime                @default(now()) @db.Timestamp(6)
  updated_at              DateTime                @default(now()) @db.Timestamp(6)
  agreement_rent_cycles   agreement_rent_cycles[]
  brokers                 brokers?                @relation(fields: [broker_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_agreement_broker")
  properties              properties              @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_agreement_property")
  tenants                 tenants                 @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_agreement_tenant")
  brokerage_payments      brokerage_payments?
  deposit_payments        deposit_payments?
  notification_logs       notification_logs[]
  payments                payments[]
  rent_ledgers            rent_ledgers[]

  @@index([property_id], map: "idx_agreements_property")
  @@index([status], map: "idx_agreements_status")
  @@index([tenant_id], map: "idx_agreements_tenant")
  @@schema("public")
}

model brokerage_payments {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agreement_id     String        @unique @db.Uuid
  brokerage_type   BrokerageType
  brokerage_value  Decimal       @db.Decimal(10, 2)
  brokerage_amount Decimal       @db.Decimal(12, 2)
  is_paid          Boolean       @default(false)
  paid_on          DateTime?     @db.Date
  payment_mode     PaymentMode?
  cheque_number    String?       @db.VarChar(100)
  cheque_date      DateTime?     @db.Date
  bank_name        String?       @db.VarChar(255)
  cheque_photo     String?       @db.VarChar(500)
  remarks          String?
  created_at       DateTime      @default(now()) @db.Timestamp(6)
  updated_at       DateTime      @default(now()) @db.Timestamp(6)
  agreements       agreements    @relation(fields: [agreement_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_brokerage_agreement")

  @@schema("public")
}

model brokers {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String       @db.VarChar(255)
  contact_no String       @db.VarChar(20)
  email      String?      @db.VarChar(255)
  address    String?
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now()) @db.Timestamp(6)
  updated_at DateTime     @default(now()) @db.Timestamp(6)
  agreements agreements[]

  @@schema("public")
}

model deposit_payments {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agreement_id  String      @unique @db.Uuid
  amount        Decimal     @db.Decimal(12, 2)
  received_on   DateTime    @db.Date
  payment_mode  PaymentMode
  cheque_number String?     @db.VarChar(100)
  cheque_date   DateTime?   @db.Date
  bank_name     String?     @db.VarChar(255)
  cheque_photo  String?     @db.VarChar(500)
  remarks       String?
  created_at    DateTime    @default(now()) @db.Timestamp(6)
  updated_at    DateTime    @default(now()) @db.Timestamp(6)
  agreements    agreements  @relation(fields: [agreement_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_deposit_agreement")

  @@schema("public")
}

model notification_logs {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            NotificationType
  channel         NotificationChannel
  agreement_id    String              @db.Uuid
  tenant_id       String              @db.Uuid
  property_id     String              @db.Uuid
  ledger_id       String?             @db.Uuid
  reference_month String?             @db.VarChar(7)
  status          NotificationStatus
  sent_at         DateTime?           @db.Timestamp(6)
  failure_reason  String?
  created_at      DateTime            @default(now()) @db.Timestamp(6)
  agreements      agreements          @relation(fields: [agreement_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notif_agreement")
  rent_ledgers    rent_ledgers?       @relation(fields: [ledger_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notif_ledger")
  properties      properties          @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notif_property")
  tenants         tenants             @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notif_tenant")

  @@unique([type, channel, agreement_id, reference_month])
  @@index([status], map: "idx_notification_logs_status")
  @@index([type], map: "idx_notification_logs_type")
  @@schema("public")
}

model payments {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ledger_id          String       @db.Uuid
  agreement_id       String       @db.Uuid
  property_id        String       @db.Uuid
  tenant_id          String       @db.Uuid
  amount             Decimal      @db.Decimal(12, 2)
  payment_mode       PaymentMode
  cheque_number      String?      @db.VarChar(100)
  cheque_date        DateTime?    @db.Date
  bank_name          String?      @db.VarChar(255)
  cheque_photo       String?      @db.VarChar(500)
  upi_transaction_id String?      @db.VarChar(255)
  received_on        DateTime     @db.Date
  is_advance         Boolean      @default(false)
  advance_for_month  String?      @db.VarChar(7)
  remarks            String?
  created_at         DateTime     @default(now()) @db.Timestamp(6)
  updated_at         DateTime     @default(now()) @db.Timestamp(6)
  agreements         agreements   @relation(fields: [agreement_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_agreement")
  rent_ledgers       rent_ledgers @relation(fields: [ledger_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_ledger")
  properties         properties   @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_property")
  tenants            tenants      @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_tenant")

  @@index([ledger_id], map: "idx_payments_ledger")
  @@index([tenant_id], map: "idx_payments_tenant")
  @@schema("public")
}

model properties {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_type_id       String                 @db.Uuid
  name                   String                 @db.VarChar(255)
  address                String
  area_sq_ft             Decimal                @db.Decimal(10, 2)
  purchase_date          DateTime               @db.Date
  purchase_amount        Decimal                @db.Decimal(15, 2)
  purchase_agreement_pdf String?                @db.VarChar(500)
  status                 PropertyStatus         @default(VACANT)
  is_active              Boolean                @default(true)
  created_at             DateTime               @default(now()) @db.Timestamp(6)
  updated_at             DateTime               @default(now()) @db.Timestamp(6)
  agreements             agreements[]
  notification_logs      notification_logs[]
  payments               payments[]
  property_types         property_types         @relation(fields: [property_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_property_type")
  rent_ledgers           rent_ledgers[]
  user_property_access   user_property_access[]

  @@index([status], map: "idx_properties_status")
  @@schema("public")
}

model property_types {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique @db.VarChar(100)
  description String?
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now()) @db.Timestamp(6)
  updated_at  DateTime     @default(now()) @db.Timestamp(6)
  properties  properties[]

  @@schema("public")
}

model rent_ledgers {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agreement_id          String                @db.Uuid
  property_id           String                @db.Uuid
  tenant_id             String                @db.Uuid
  rent_cycle_id         String                @db.Uuid
  ledger_month          String                @db.VarChar(7)
  rent_amount           Decimal               @db.Decimal(12, 2)
  balance_from_previous Decimal               @default(0) @db.Decimal(12, 2)
  total_due             Decimal               @db.Decimal(12, 2)
  paid_amount           Decimal               @default(0) @db.Decimal(12, 2)
  balance_carried       Decimal               @default(0) @db.Decimal(12, 2)
  due_date              DateTime              @db.Date
  status                LedgerStatus          @default(PENDING)
  created_at            DateTime              @default(now()) @db.Timestamp(6)
  updated_at            DateTime              @default(now()) @db.Timestamp(6)
  notification_logs     notification_logs[]
  payments              payments[]
  agreements            agreements            @relation(fields: [agreement_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ledger_agreement")
  properties            properties            @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ledger_property")
  agreement_rent_cycles agreement_rent_cycles @relation(fields: [rent_cycle_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ledger_rent_cycle")
  tenants               tenants               @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ledger_tenant")

  @@unique([agreement_id, ledger_month])
  @@index([agreement_id], map: "idx_rent_ledgers_agreement")
  @@index([due_date], map: "idx_rent_ledgers_due_date")
  @@index([status], map: "idx_rent_ledgers_status")
  @@schema("public")
}

model tenants {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name         String              @db.VarChar(255)
  email             String              @unique @db.VarChar(255)
  whats_app_no      String              @db.VarChar(20)
  dob               DateTime            @db.Date
  aadhar_photo      String?             @db.VarChar(500)
  pan_photo         String?             @db.VarChar(500)
  permanent_address String
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  agreements        agreements[]
  notification_logs notification_logs[]
  payments          payments[]
  rent_ledgers      rent_ledgers[]

  @@schema("public")
}

model user_property_access {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String     @db.Uuid
  property_id String     @db.Uuid
  valid_from  DateTime   @db.Date
  valid_to    DateTime   @db.Date
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.Timestamp(6)
  updated_at  DateTime   @default(now()) @db.Timestamp(6)
  properties  properties @relation(fields: [property_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_upa_property")
  users       users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_upa_user")

  @@unique([user_id, property_id])
  @@index([user_id], map: "idx_user_property_access_user")
  @@schema("public")
}

model users {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String                 @db.VarChar(255)
  email                String                 @unique @db.VarChar(255)
  password             String                 @db.VarChar(255)
  role                 Role                   @default(USER)
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  updated_at           DateTime               @default(now()) @db.Timestamp(6)
  user_property_access user_property_access[]

  @@schema("public")
}

enum AgreementStatus {
  ACTIVE
  EXPIRED
  TERMINATED

  @@schema("public")
}

enum BrokerageType {
  PERCENTAGE
  AMOUNT

  @@schema("public")
}

enum LedgerStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE

  @@schema("public")
}

enum NotificationChannel {
  EMAIL
  WHATSAPP

  @@schema("public")
}

enum NotificationStatus {
  SENT
  FAILED

  @@schema("public")
}

enum NotificationType {
  RENT_REMINDER_5DAY
  RENT_DUE
  AGREEMENT_EXPIRY_30DAY

  @@schema("public")
}

enum PaymentMode {
  CASH
  CHEQUE
  UPI

  @@schema("public")
}

enum PropertyStatus {
  VACANT
  RENTED

  @@schema("public")
}

enum Role {
  ADMIN
  USER

  @@schema("public")
}
